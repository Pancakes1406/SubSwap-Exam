  ["Tomato",         "Lemon",            "flavor"],   // both add acidity to a dish
  ["Canned Tomatoes","Tomato Paste",     "pairing"],  // direct swap with water adjustment
  ["Canned Tomatoes","Salsa",            "flavor"],   // both are tomato-based sauces
  ["Tomato Paste",   "Ketchup",          "flavor"],   // ketchup is sweetened tomato paste
  ["Spinach",        "Kale",             "pairing"],  // near-identical swap in cooked dishes — kale not in list, skip
