];

// ─── BUILD GRAPH ────────────────────────────────────────────────────────────
const graph = {};
ingredients.forEach(i => { graph[i] = {}; });

edges.forEach(([a, b, type]) => {
  if (!graph[a] || !graph[b]) return; // skip if ingredient not in list
  if (a === b) return;
  if (!graph[a][b]) graph[a][b] = [];
  if (!graph[b][a]) graph[b][a] = [];
  if (!graph[a][b].includes(type)) graph[a][b].push(type);
  if (!graph[b][a].includes(type)) graph[b][a].push(type);
});

function scoreSubstitute(target, candidate) {
  const rels = graph[target]?.[candidate];
  if (!rels || rels.length === 0) return 0;
  return rels.reduce((sum, r) => sum + (WEIGHTS[r] || 0), 0);
}

function getStrengthLabel(score) {
  if (score >= 0.8) return "strong";
  if (score >= 0.4) return "moderate";
  return "weak";
}

function buildExplanation(target, candidate, rels) {
  if (!rels || rels.length === 0) return "";
  const parts = [];
  if (rels.includes("pairing")) parts.push("they serve the same functional role in the dish");
  if (rels.includes("flavor"))  parts.push("they share a similar flavor profile");
  if (rels.includes("cuisine")) parts.push("they appear in the same cooking contexts");
  const joined = parts.length === 1
    ? parts[0]
    : parts.slice(0, -1).join(", ") + " and " + parts[parts.length - 1];
  return `${candidate} works as a substitute for ${target} because ${joined}.`;
}

function getRecommendations(target) {
  return ingredients
    .filter(i => i !== target)
    .map(candidate => ({
      name: candidate,
      score: scoreSubstitute(target, candidate),
      rels: graph[target]?.[candidate] || []
    }))
    .filter(r => r.score > 0)
    .sort((a, b) => b.score - a.score)
    .slice(0, 5);
}

// ─── UI ─────────────────────────────────────────────────────────────────────
const selectEl  = document.getElementById('ingredient-select');
const quickGrid = document.getElementById('quick-grid');

const sorted = [...ingredients].sort();

sorted.forEach(ing => {
  const opt = document.createElement('option');
  opt.value = ing; opt.textContent = ing;
  selectEl.appendChild(opt);
});

ingredients.forEach(ing => {
  const btn = document.createElement('button');
  btn.className = 'quick-btn';
  btn.textContent = ing;
  btn.onclick = () => {
    selectEl.value = ing;
    document.querySelectorAll('.quick-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderResults(ing);
  };
  quickGrid.appendChild(btn);
});

function handleSelect(val) {
  document.querySelectorAll('.quick-btn').forEach(b => {
    b.classList.toggle('active', b.textContent === val);
  });
  if (val) renderResults(val);
}

function renderResults(target) {
  const section = document.getElementById('results-section');
  const recs = getRecommendations(target);

  if (recs.length === 0) {
    section.innerHTML = `<div class="empty-state"><div class="empty-icon">🤔</div><p>No substitutes found for <strong>${target}</strong> in the current dataset.</p></div>`;
    return;
  }

  const maxScore = recs[0].score;
  let html = `
    <div class="results-header">
      <span class="results-title">Best substitutes for ${target}</span>
      <span class="results-count">${recs.length} result${recs.length !== 1 ? 's' : ''}</span>
    </div>`;

  recs.forEach((rec, i) => {
    const strength = getStrengthLabel(rec.score);
    const pct      = Math.round((rec.score / maxScore) * 100);
    const expl     = buildExplanation(target, rec.name, rec.rels);
    html += `
      <div class="result-card" style="animation-delay:${i * 0.06}s">
        <div class="rank-number">${i + 1}</div>
        <div class="card-body">
          <div class="card-top">
            <span class="ingredient-name">${rec.name}</span>
            <span class="strength-badge strength-${strength}">${strength}</span>
          </div>
          <div class="score-bar-wrap">
            <div class="score-bar-bg"><div class="score-bar-fill" style="width:${pct}%"></div></div>
            <span class="score-text">${rec.score.toFixed(2)}</span>
          </div>
          <p class="explanation">${expl}</p>
        </div>
      </div>`;
  });

  section.innerHTML = html;
}
</script>
</body>
</html>
